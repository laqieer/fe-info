{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "desc": { "$ref": "urn:definitions#/definitions/Description" },
            "label": { "$ref": "urn:definitions#/definitions/Label" },
            "addr": { "$ref": "urn:definitions#/definitions/RegionHex" },
            "size": { "$ref": "urn:definitions#/definitions/RegionHex" },
            "mode": { "$ref": "urn:definitions#/definitions/Mode" },
            "params": {
                "oneOf": [
                    { "type": "null" },
                    {
                        "type": "array",
                        "items": { "$ref": "urn:definitions#/definitions/Param" },
                        "minItems": 1
                    }
                ]
            },
            "return": {
                "oneOf": [
                    { "type": "null" },
                    { "$ref": "urn:definitions#/definitions/Param" }
                ]
            },
            "notes": { "type": "string" },
            "line": { "$ref": "urn:definitions#/definitions/Line" }
        },
        "required": ["desc", "label", "addr", "size", "mode", "params", "return"],
        "additionalProperties": false
    }
}
