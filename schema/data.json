{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "desc": { "$ref": "urn:definitions#/definitions/Description" },
            "label": { "$ref": "urn:definitions#/definitions/Label" },
            "type": { "$ref": "urn:definitions#/definitions/NullableType" },
            "addr": { "$ref": "urn:definitions#/definitions/RegionHex" },
            "size": { "$ref": "urn:definitions#/definitions/RegionHex" },
            "count": { "$ref": "urn:definitions#/definitions/HexInt" },
            "cat": { "$ref": "urn:definitions#/definitions/Category" },
            "enum": { "$ref": "urn:definitions#/definitions/Label" },
            "notes": { "type": "string" },
            "line": { "$ref": "urn:definitions#/definitions/Line" }
        },
        "required": ["desc", "label", "type", "addr"],
        "additionalProperties": false
    }
}
