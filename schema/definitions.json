{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "urn:definitions",
    "definitions": {
        "Name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "Label": {
            "type": "string",
            "pattern": "^[A-Za-z_.][A-Za-z0-9_.]*$"
        },
        "Description": {
            "type": "string",
            "minLength": 1
        },
        "Type": {
            "type": "string",
            "minLength": 1
        },
        "NullableType": {
            "oneOf": [
                { "type": "null" },
                { "$ref": "#/definitions/Type" }
            ]
        },
        "HexInt": {
            "type": "string",
            "pattern": "^[0-9A-Fa-f]+$"
        },
        "RegionHex": {
            "oneOf": [
                { "$ref": "#/definitions/HexInt" },
                {
                    "type": "object",
                    "properties": {
                        "U": { "$ref": "#/definitions/HexInt" },
                        "E": { "$ref": "#/definitions/HexInt" },
                        "J": { "$ref": "#/definitions/HexInt" },
                        "C": { "$ref": "#/definitions/HexInt" },
                        "B": { "$ref": "#/definitions/HexInt" }
                    },
                    "additionalProperties": false,
                    "minProperties": 1
                }
            ]
        },
        "Line": {
            "type": "string"
        },
        "Mode": {
            "type": "string",
            "enum": ["thumb", "arm"]
        },
        "Category": {
            "type": "string",
            "enum": [
                "flags",
                "ascii",
                "text",
                "gfx",
                "tilemap",
                "palette",
                "oam_frame",
                "bg_blocks",
                "bg_map",
                "pcm",
                "thumb",
                "arm"
            ]
        },
        "Param": {
            "type": "object",
            "properties": {
                "desc": { "$ref": "#/definitions/Description" },
                "type": { "$ref": "#/definitions/Type" }
            },
            "required": ["desc", "type"],
            "additionalProperties": false
        }
    }
}
