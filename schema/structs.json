{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "desc": { "$ref": "urn:definitions#/definitions/Description" },
            "label": { "$ref": "urn:definitions#/definitions/Label" },
            "size": { "$ref": "urn:definitions#/definitions/HexInt" },
            "notes": { "type": "string" },
            "vars": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "desc": { "$ref": "urn:definitions#/definitions/Description" },
                        "label": { "$ref": "urn:definitions#/definitions/Label" },
                        "type": { "$ref": "urn:definitions#/definitions/NullableType" },
                        "offset": { "$ref": "urn:definitions#/definitions/HexInt" },
                        "count": { "$ref": "urn:definitions#/definitions/HexInt" },
                        "cat": { "$ref": "urn:definitions#/definitions/Category" },
                        "enum": { "$ref": "urn:definitions#/definitions/Label" },
                        "notes": { "type": "string" }
                    },
                    "required": ["desc", "label", "type", "offset"],
                    "additionalProperties": false
                }
            }
        },
        "required": ["desc", "label", "size", "vars"],
        "additionalProperties": false
    }
}
